<?xml version="1.0" encoding="utf-8"?>
<!--
  Sunflower splash icon (240×240dp)
  12 copies of Outfit Bold-style "L" rotated 30° each, pivoting at center (120,120)

  L の視覚的中心 = (120,120)（フォントテキスト描画との整合性）
  108dp パスをそのまま 240dp 空間の中心(120,120) に移植:
    元パス (center=54,54): M50,36 L58,36 L58,65 L70,65 L70,72 L50,72
    オフセット = 120 - 54 = +66
    新パス: M116,102 L124,102 L124,131 L136,131 L136,138 L116,138 Z

  Wrapped in l_group for AnimatedVectorDrawable scale+fade animation.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="240dp"
    android:height="240dp"
    android:viewportWidth="240"
    android:viewportHeight="240">

    <group
        android:name="l_group"
        android:pivotX="120"
        android:pivotY="120"
        android:scaleX="0.7"
        android:scaleY="0.7"
        android:alpha="0">

        <group android:pivotX="120" android:pivotY="120" android:rotation="0">
            <path android:fillColor="#FFB800"
                android:pathData="M116,102 L124,102 L124,131 L136,131 L136,138 L116,138 Z"/>
        </group>
        <group android:pivotX="120" android:pivotY="120" android:rotation="30">
            <path android:fillColor="#FFB800"
                android:pathData="M116,102 L124,102 L124,131 L136,131 L136,138 L116,138 Z"/>
        </group>
        <group android:pivotX="120" android:pivotY="120" android:rotation="60">
            <path android:fillColor="#FFB800"
                android:pathData="M116,102 L124,102 L124,131 L136,131 L136,138 L116,138 Z"/>
        </group>
        <group android:pivotX="120" android:pivotY="120" android:rotation="90">
            <path android:fillColor="#FFB800"
                android:pathData="M116,102 L124,102 L124,131 L136,131 L136,138 L116,138 Z"/>
        </group>
        <group android:pivotX="120" android:pivotY="120" android:rotation="120">
            <path android:fillColor="#FFB800"
                android:pathData="M116,102 L124,102 L124,131 L136,131 L136,138 L116,138 Z"/>
        </group>
        <group android:pivotX="120" android:pivotY="120" android:rotation="150">
            <path android:fillColor="#FFB800"
                android:pathData="M116,102 L124,102 L124,131 L136,131 L136,138 L116,138 Z"/>
        </group>
        <group android:pivotX="120" android:pivotY="120" android:rotation="180">
            <path android:fillColor="#FFB800"
                android:pathData="M116,102 L124,102 L124,131 L136,131 L136,138 L116,138 Z"/>
        </group>
        <group android:pivotX="120" android:pivotY="120" android:rotation="210">
            <path android:fillColor="#FFB800"
                android:pathData="M116,102 L124,102 L124,131 L136,131 L136,138 L116,138 Z"/>
        </group>
        <group android:pivotX="120" android:pivotY="120" android:rotation="240">
            <path android:fillColor="#FFB800"
                android:pathData="M116,102 L124,102 L124,131 L136,131 L136,138 L116,138 Z"/>
        </group>
        <group android:pivotX="120" android:pivotY="120" android:rotation="270">
            <path android:fillColor="#FFB800"
                android:pathData="M116,102 L124,102 L124,131 L136,131 L136,138 L116,138 Z"/>
        </group>
        <group android:pivotX="120" android:pivotY="120" android:rotation="300">
            <path android:fillColor="#FFB800"
                android:pathData="M116,102 L124,102 L124,131 L136,131 L136,138 L116,138 Z"/>
        </group>
        <group android:pivotX="120" android:pivotY="120" android:rotation="330">
            <path android:fillColor="#FFB800"
                android:pathData="M116,102 L124,102 L124,131 L136,131 L136,138 L116,138 Z"/>
        </group>

    </group>
</vector>
